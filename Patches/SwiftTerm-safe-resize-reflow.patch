+    private func safeReflow(_ oldCols: Int, _ newCols: Int, _ newRows: Int)
+    {
+        let oldLineCount = lines.count
+        guard oldLineCount > 0 else { return }
+
+        let oldYBase = yBase
+        let oldYDisp = yDisp
+        let oldCursorAbsoluteY = yBase + y
+
+        var outputLines: [BufferLine] = []
+        var oldToNewLineMap = Array(repeating: 0, count: oldLineCount)
+        var index = 0
+
+        while index < oldLineCount {
+            let start = index
+            var end = index
+            while end + 1 < oldLineCount && lines[end + 1].isWrapped {
+                end += 1
+            }
+
+            var wrappedLines: [BufferLine] = []
+            wrappedLines.reserveCapacity(end - start + 1)
+            for lineIndex in start...end {
+                wrappedLines.append(lines[lineIndex])
+            }
+
+            let containsCursor = oldCursorAbsoluteY >= start && oldCursorAbsoluteY <= end
+            let lineLength = wrappedLines.count == 1 ? wrappedLines[0].getTrimmedLength() : oldCols + 1
+            let shouldReflow = canSafelyReflow(wrappedLines, containsCursor: containsCursor)
+                && (wrappedLines.count > 1 || lineLength > newCols)
+
+            if shouldReflow {
+                let flattened = flattenedReflowCells(wrappedLines, oldCols: oldCols)
+                let reflowedLines = makeReflowedLines(
+                    from: flattened.cells,
+                    newCols: newCols,
+                    firstLineWrapped: false
+                )
+
