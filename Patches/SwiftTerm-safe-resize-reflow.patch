+    private func canSafelyReflow(_ wrappedLines: [BufferLine], containsCursor: Bool) -> Bool
+    {
+        guard !containsCursor else { return false }
+        guard let firstLine = wrappedLines.first, !firstLine.isWrapped else { return false }
+
+        for line in wrappedLines {
+            if line.images != nil || line.renderMode != .single {
+                return false
+            }
+        }
+
+        return true
+    }
