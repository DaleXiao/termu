+            with: outputLines,
+            oldToNewLineMap: oldToNewLineMap,
+            oldYBase: oldYBase,
+            oldYDisp: oldYDisp,
+            oldCursorAbsoluteY: oldCursorAbsoluteY,
+            newCols: newCols,
+            newRows: newRows
+        )
+    }
