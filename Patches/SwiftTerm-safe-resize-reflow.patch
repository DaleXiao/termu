+                        let mappedRelativeLine = min(
+                            flattened.oldLineOffsets[offsetIndex] / newCols,
+                            reflowedLines.count - 1
+                        )
+                        oldToNewLineMap[start + offsetIndex] = newStart + mappedRelativeLine
+                    }
+                } else {
+                    for relativeIndex in 0..<wrappedLines.count {
+                        outputLines.append(resizedCopy(wrappedLines[relativeIndex], cols: newCols))
+                        oldToNewLineMap[start + relativeIndex] = outputLines.count - 1
+                    }
+                }
+            } else {
+                for relativeIndex in 0..<wrappedLines.count {
+                    outputLines.append(resizedCopy(wrappedLines[relativeIndex], cols: newCols))
+                    oldToNewLineMap[start + relativeIndex] = outputLines.count - 1
+                }
+            }
+
