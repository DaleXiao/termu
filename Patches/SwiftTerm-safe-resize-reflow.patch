+    private func flattenedReflowCells(
+        _ wrappedLines: [BufferLine],
+        oldCols: Int
+    ) -> (cells: [CharData], oldLineOffsets: [Int])
+    {
+        var cells: [CharData] = []
+        var oldLineOffsets: [Int] = []
+        var displayOffset = 0
+
+        for index in 0..<wrappedLines.count {
+            oldLineOffsets.append(displayOffset)
+
+            let line = wrappedLines[index]
+            let nextLine = index == wrappedLines.count - 1 ? nil : wrappedLines[index + 1]
+            let length = min(line.count, getWrappedLineTrimmedLength(line, nextLine, oldCols))
+            guard length > 0 else { continue }
+
+            for col in 0..<length {
+                let cell = line[col]
+                guard cell.width != 0 else { continue }
+
+                cells.append(cell)
+                displayOffset += max(Int(cell.width), 1)
+            }
+        }
+
+        return (cells, oldLineOffsets)
+    }
+
+    private func makeReflowedLines(
+        from cells: [CharData],
+        newCols: Int,
+        firstLineWrapped: Bool
+    ) -> [BufferLine]
+    {
+        guard !cells.isEmpty else { return [] }
+
+        var result: [BufferLine] = []
+        var line = BufferLine(cols: newCols, fillData: CharData.Null, isWrapped: firstLineWrapped)
+        var col = 0
+
+        func appendLine() {
+            result.append(line)
+            line = BufferLine(cols: newCols, fillData: CharData.Null, isWrapped: true)
+            col = 0
+        }
+
+        for cell in cells {
+            let width = max(Int(cell.width), 1)
+            if col > 0 && col + width > newCols {
+                appendLine()
+            }
+            if width == 2 && col == newCols - 1 {
+                appendLine()
+            }
+
+            line[col] = cell
+            if width > 1 && col + 1 < newCols {
+                line[col + 1] = CharData(attribute: cell.attribute, code: 0, size: 0)
+            }
+            col += width
+        }
+
+        result.append(line)
+        return result
+    }
